# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
dist/
build/

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json

# Linting
.ruff_cache/

# IDE
.idea/
.vscode/
*.swp
*.swo

# Virtual environments
.venv/
venv/
env/

# Environment
.env
.env.*

# Node
node_modules/

# OS
.DS_Store
Thumbs.db

# Dev folders (NEVER PUBLISH - development artifacts only)
# Wildcard pattern catches all: docs_dev, scripts_dev, tests_dev, samples_dev,
# examples_dev, downloads_dev, libs_dev, builds_dev, etc.
*_dev/

# Rust
target/
Cargo.lock

# Local tool artifacts
.tldr/
.tldrignore
.tldr_session_*
.claude/**
# The PROJECT memory scope lives in-repo under .claude/ and MUST be tracked +
# pushed (the shared, cross-dev wiki memory). Re-include it via these exceptions.
!.claude/project/
!.claude/project/memory/
!.claude/project/memory/**
.rechecker/
.serena/
llm_externalizer_output/
rck-*.md

# Agent / tool reports (may contain private data — never commit)
/reports/
/reports_dev/

# Janitor per-session runtime state + logs (regeneratable — never commit)
/.janitor/

# git-cliff scratch — ephemeral release notes between bump and push
.git-cliff-release-notes.md
